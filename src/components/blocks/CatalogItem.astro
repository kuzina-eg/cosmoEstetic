---
import Price from '@components/blocks/Price.astro';
import Button from '@components/modules/Button.astro';
import typograf from '@utils/typograf';

interface Props {
  image: string;
  title: string;
  description: string;
  price: string;
  oldPrice?: string;
  badges?: string[];
}

const { image, title, description, price, oldPrice, badges = [] } = Astro.props;
---
<article class="item-product">
  <a href="#" class="item-product__image-link">
    <img class="item-product__image lazy" width="400" height="400" data-src={`${image}@1x.webp`} data-srcset={`${image}@2x.webp 2x`} alt={title} />
  </a>
  <div class="item-product__info">
    <h3 class="item-product__title"><a href="#" set:html={typograf(title)} /></h3>
    <p class="item-product__desc" set:html={typograf(description)} />
    {badges.length > 0 && (
      <div class="item-product__badges">
        {badges.map((b) => <span class="item-product__badge">{b}</span>)}
      </div>
    )}
  </div>
  <Price price={price} oldPrice={oldPrice} class="item-product__price" />
  <div class="item-product__action">
    <Button type="link" href="#cart" style="outline" fill icon="bag" class="item-product__button">Добавить в&nbsp;корзину</Button>
  </div>
</article>
