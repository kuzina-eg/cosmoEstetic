---
import Icon from '@components/modules/Icon.astro';

interface Props {
    type?: 'button' | 'submit' | 'link' | 'span';
    size?: 'sm' | 'lg';
    style?: 'second' | 'link' | 'outline' | 'square';
    fill?: boolean;
    center?: boolean;
    href?: string;
    ariaLabel?: string;
    icon?: string;
    disabled?: boolean;
    isText?: boolean;
    textClass?: string;
    class?: string;
    [x: string]: any;
}

const {
    type = 'button',
    size,
    style,
    fill = false,
    center = false,
    href = '',
    ariaLabel,
    icon,
    disabled,
    direction,
    isText = true,
    textClass,
    class: className,
    ...rest
} = Astro.props;

const ButtonEl = type === 'link' ? 'a' : type == 'span' ? 'span' : 'button';
let buttonClass = 'ui-button';

const styles = {
    second: `${buttonClass}--second`,
    link: `${buttonClass}--link`,
    outline: `${buttonClass}--outline`,
    square: `${buttonClass}--square`,
    narrow: `${buttonClass}--narrow`,
};

const sizes = {
    sm: `${buttonClass}--sm`,
    lg: `${buttonClass}--lg`,
};

const classList =[
    buttonClass,
    styles[style],
    sizes[size],
    fill ? `${buttonClass}--fill`: '',
    center ? `${buttonClass}--center`: '',
    className,
    disabled && type === 'link' ? 'is-disabled' : '',
]
---
<ButtonEl
    type={(type !== 'link' && type !== 'span') ? type : null}
    href={type === 'link' ? href : null}
    class:list={classList}
    aria-label={ariaLabel}
    disabled={((type === 'submit' || type === 'button') && disabled) ? 'disabled' : null}
    tabindex={type === 'link' && disabled ? -1 : null}
    {...rest}
>
    {
        isText ?

        <span class:list={[
            `${buttonClass}__text`,
            textClass
        ]}>
            <slot />
        </span> : ''
    }
    {
        icon ? <Icon class={`${buttonClass}__icon`} name={icon}></Icon> : ''
    }
</ButtonEl>
